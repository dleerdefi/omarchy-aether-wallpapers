#!/bin/bash

# Save an Aether wallpaper to the current Omarchy theme and set it as active background.
# Usage: aether-save-to-theme <path-to-wallpaper>

if [[ -z $1 ]]; then
  echo "Usage: aether-save-to-theme <path-to-wallpaper>" >&2
  exit 1
fi

WALLPAPER="$1"
FILENAME="$(basename "$WALLPAPER")"
THEME_NAME="$(cat "$HOME/.config/omarchy/current/theme.name" 2>/dev/null)"

if [[ -z "$THEME_NAME" ]]; then
  notify-send "No active theme" -t 2000
  exit 1
fi

if [[ ! -f "$WALLPAPER" ]]; then
  notify-send "Wallpaper not found" -t 2000
  exit 1
fi

USER_BG_DIR="$HOME/.config/omarchy/backgrounds/$THEME_NAME"
mkdir -p "$USER_BG_DIR"

if ! cp "$WALLPAPER" "$USER_BG_DIR/$FILENAME"; then
  notify-send "Failed to save wallpaper" -t 2000
  exit 1
fi

omarchy-theme-bg-set "$USER_BG_DIR/$FILENAME"
notify-send "Saved to $THEME_NAME" "$FILENAME" -t 2000
